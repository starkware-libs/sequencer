# =============================================================================
# Validation-Only Node - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values before running docker compose.

# Docker image settings
IMAGE_TAG=latest
IMAGE_REGISTRY=ghcr.io/starkware-libs/sequencer

# Logging
RUST_LOG=info
RUST_BACKTRACE=1

# Data directory (host path for persistent storage)
DATA_DIR=./data
