{
  "apiVersion": "v1",
  "kind": "Service",
  "metadata": {
    "name": "broadcast-network-stress-test-headless"
  },
  "spec": {
    "clusterIP": "None",
    "selector": {
      "app": "broadcast-network-stress-test"
    },
    "ports": [
      {
        "port": 2000,
        "targetPort": 2000,
        "name": "metrics"
      },
      {
        "port": 10000,
        "targetPort": 10000,
        "protocol": "UDP",
        "name": "p2p-udp"
      },
      {
        "port": 10000,
        "targetPort": 10000,
        "protocol": "TCP",
        "name": "p2p-tcp"
      }
    ]
  }
}
