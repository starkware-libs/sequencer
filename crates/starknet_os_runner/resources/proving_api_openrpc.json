{
    "openrpc": "1.0.0-rc1",
    "info": {
        "version": "0.10.0",
        "title": "Starknet OS Runner Proving API",
        "description": "JSON-RPC API for proving Starknet transactions via the Starknet OS Runner.",
        "license": {
            "name": "Apache 2.0",
            "url": "https://www.apache.org/licenses/LICENSE-2.0"
        }
    },
    "servers": [],
    "methods": [
        {
            "name": "rpc.discover",
            "summary": "Returns the OpenRPC specification of this API.",
            "params": [],
            "result": {
                "name": "openrpc_document",
                "description": "The OpenRPC document describing this API.",
                "schema": {
                    "title": "OpenRPC document",
                    "type": "object"
                }
            }
        },
        {
            "name": "starknet_specVersion",
            "summary": "Returns the Starknet RPC specification version.",
            "params": [],
            "result": {
                "name": "spec_version",
                "description": "The Starknet RPC specification version (e.g. \"0.10.0\").",
                "schema": {
                    "title": "Spec version",
                    "type": "string"
                }
            }
        },
        {
            "name": "starknet_proveTransaction",
            "summary": "Proves a transaction on top of the specified block.",
            "params": [
                {
                    "name": "block_id",
                    "description": "The block to execute the transaction on.",
                    "required": true,
                    "schema": {
                        "title": "Block id",
                        "$ref": "#/components/schemas/BLOCK_ID"
                    }
                },
                {
                    "name": "transaction",
                    "description": "The transaction to prove (must be an Invoke transaction).",
                    "required": true,
                    "schema": {
                        "title": "RPC transaction",
                        "$ref": "#/components/schemas/RPC_TRANSACTION"
                    }
                }
            ],
            "result": {
                "name": "result",
                "description": "The proof, proof facts, and L2-to-L1 messages.",
                "schema": {
                    "title": "Prove transaction result",
                    "$ref": "#/components/schemas/PROVE_TRANSACTION_RESULT"
                }
            },
            "errors": [
                {
                    "$ref": "#/components/errors/BLOCK_NOT_FOUND"
                },
                {
                    "$ref": "#/components/errors/ACCOUNT_VALIDATION_FAILED"
                },
                {
                    "$ref": "#/components/errors/UNSUPPORTED_TX_VERSION"
                },
                {
                    "$ref": "#/components/errors/SERVICE_BUSY"
                }
            ]
        }
    ],
    "components": {
        "schemas": {
            "FELT": {
                "title": "Field element",
                "description": "A field element represented as a hex string with 0x prefix.",
                "type": "string",
                "pattern": "^0x[0-9a-fA-F]{1,64}$"
            },
            "BLOCK_ID": {
                "title": "Block id",
                "description": "Identifies a block by hash, number, or tag.",
                "oneOf": [
                    {
                        "title": "Block hash",
                        "type": "object",
                        "properties": {
                            "block_hash": {
                                "title": "Block hash",
                                "$ref": "#/components/schemas/FELT"
                            }
                        },
                        "required": [
                            "block_hash"
                        ]
                    },
                    {
                        "title": "Block number",
                        "type": "object",
                        "properties": {
                            "block_number": {
                                "title": "Block number",
                                "type": "integer",
                                "minimum": 0
                            }
                        },
                        "required": [
                            "block_number"
                        ]
                    },
                    {
                        "title": "Block tag",
                        "type": "string",
                        "enum": [
                            "latest",
                            "pending"
                        ]
                    }
                ]
            },
            "RPC_TRANSACTION": {
                "title": "RPC transaction",
                "description": "A Starknet RPC transaction. Only Invoke transactions are supported for proving.",
                "type": "object"
            },
            "PROOF": {
                "title": "Proof",
                "description": "The generated proof as a list of field elements.",
                "type": "array",
                "items": {
                    "$ref": "#/components/schemas/FELT"
                }
            },
            "PROOF_FACTS": {
                "title": "Proof facts",
                "description": "The proof facts as a mapping of keys to values.",
                "type": "object",
                "additionalProperties": {
                    "type": "array",
                    "items": {
                        "$ref": "#/components/schemas/FELT"
                    }
                }
            },
            "MSG_TO_L1": {
                "title": "Message to L1",
                "description": "A message sent from L2 to L1 during execution.",
                "type": "object",
                "properties": {
                    "from_address": {
                        "title": "From address",
                        "$ref": "#/components/schemas/FELT"
                    },
                    "to_address": {
                        "title": "To address",
                        "$ref": "#/components/schemas/FELT"
                    },
                    "payload": {
                        "title": "Payload",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/FELT"
                        }
                    }
                },
                "required": [
                    "from_address",
                    "to_address",
                    "payload"
                ]
            },
            "PROVE_TRANSACTION_RESULT": {
                "title": "Prove transaction result",
                "description": "The result of proving a transaction.",
                "type": "object",
                "properties": {
                    "proof": {
                        "title": "Proof",
                        "$ref": "#/components/schemas/PROOF"
                    },
                    "proof_facts": {
                        "title": "Proof facts",
                        "$ref": "#/components/schemas/PROOF_FACTS"
                    },
                    "l2_to_l1_messages": {
                        "title": "L2 to L1 messages",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/MSG_TO_L1"
                        }
                    }
                },
                "required": [
                    "proof",
                    "proof_facts",
                    "l2_to_l1_messages"
                ]
            }
        },
        "errors": {
            "BLOCK_NOT_FOUND": {
                "code": 24,
                "message": "Block not found"
            },
            "ACCOUNT_VALIDATION_FAILED": {
                "code": 55,
                "message": "Account validation failed",
                "data": {
                    "type": "string",
                    "description": "Details about the validation failure."
                }
            },
            "UNSUPPORTED_TX_VERSION": {
                "code": 61,
                "message": "The transaction version is not supported",
                "data": {
                    "type": "string",
                    "description": "Details about the unsupported version."
                }
            },
            "SERVICE_BUSY": {
                "code": -32005,
                "message": "Service is busy",
                "data": {
                    "type": "string",
                    "description": "Details about capacity and retry advice."
                }
            }
        }
    }
}
